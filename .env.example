PORT=3000
# Si ves EADDRINUSE: cierra la otra ventana de Node, ejecuta liberar-puerto-3000.bat, o pon PORT=3001

# Opción A (recomendada): una sola URL (la contraseña va URL-encoded si tiene caracteres raros)
DATABASE_URL=postgres://postgres:TU_CLAVE@127.0.0.1:5432/ftth_local

# Opción B: variables sueltas (si NO usas DATABASE_URL, comenta la línea anterior)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=ftth_local
# PGUSER=postgres
# PGPASSWORD=TU_CLAVE

# (Opcional) Catálogo GeoJSON Flashfiber FTTH: el servidor los expone en /geojson/ftth/
# FLASHFIBER_FTTH_DIR=C:\Users\ASUS\Desktop\flashfiber-ftth\public\geojson\FTTH

# (Opcional) Login fijo en pantalla de acceso: si ambas están definidas, solo ese correo/clave son válidos.
# Si las omites, el servidor acepta cualquier correo con formato válido y contraseña de 4+ caracteres (solo desarrollo).
# GIS_AUTH_EMAIL=admin@empresa.com
# GIS_AUTH_PASS=tu_clave_segura
