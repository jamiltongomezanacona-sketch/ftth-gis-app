# Vercel: MAPBOX_ACCESS_TOKEN (+ opcional PUBLIC_API_BASE) en el panel; vercel-build sobrescribe public/js/config.deploy.js
#
# Migrar tabla `rutas` local → Supabase (una sola vez, en PowerShell):
#   $env:TARGET_DATABASE_URL = "postgresql://postgres.REF:CLAVE@....pooler.supabase.com:5432/postgres?sslmode=require"
#   npm run migrate:rutas:to-supabase -- --replace-all-on-target
# Después (centrales, cierres, eventos; eventos remapea ruta_id por nombre de ruta en destino):
#   npm run migrate:aux:to-supabase -- --replace-all-on-target
# Solo eventos (borra eventos en Supabase y vuelve a insertar desde local; antes migra rutas):
#   npm run migrate:eventos:to-supabase
# (DATABASE_URL en .env = local; no subas TARGET a git)

PORT=3000
# Si ves EADDRINUSE: cierra la otra ventana de Node, ejecuta liberar-puerto-3000.bat, o pon PORT=3001

# Opción A (recomendada): una sola URL (la contraseña va URL-encoded si tiene caracteres raros)
DATABASE_URL=postgres://postgres:TU_CLAVE@127.0.0.1:5432/ftth_local

# Opción B: variables sueltas (si NO usas DATABASE_URL, comenta la línea anterior)
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=ftth_local
# PGUSER=postgres
# PGPASSWORD=TU_CLAVE

# (Opcional) Catálogo GeoJSON Flashfiber FTTH: el servidor los expone en /geojson/ftth/
# FLASHFIBER_FTTH_DIR=C:\Users\ASUS\Desktop\flashfiber-ftth\public\geojson\FTTH

# (Opcional) Login fijo en pantalla de acceso: si ambas están definidas, solo ese correo/clave son válidos.
# Si las omites, el servidor acepta cualquier correo con formato válido y contraseña de 4+ caracteres (solo desarrollo).
# Opción A — varios usuarios: ejecuta sql/09_gis_users.sql y luego:
#   npm run user:add -- persona@mail.com "contraseña_larga"
# En Supabase sin cambiar DATABASE_URL local:
#   $env:TARGET_DATABASE_URL = "postgresql://postgres.REF:CLAVE@....pooler.supabase.com:5432/postgres?sslmode=require"
#   npm run user:add -- persona@mail.com "contraseña_larga"
# Opción B — un solo usuario por variables (sin tabla):
# GIS_AUTH_EMAIL=admin@empresa.com
# GIS_AUTH_PASS=tu_clave_segura

# Obligatorio en producción (Vercel, etc.): firma JWT de sesión tras el login. Mínimo ~16 caracteres; usa un valor largo y aleatorio.
# GIS_SESSION_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
# (Solo depuración local con HTTPS forzado mal detectado) Cookie sin flag Secure:
# GIS_SESSION_COOKIE_INSECURE=1

# En local, si omites GIS_SESSION_SECRET, el servidor usa un secreto de desarrollo (no uses eso en internet).

# (Opcional) Límite de intentos de login por IP y ventana de tiempo (anti fuerza bruta). Por defecto: 25 / 15 min.
# GIS_LOGIN_RATE_MAX=25
# GIS_LOGIN_RATE_WINDOW_MS=900000
# GIS_LOGIN_RATE_DISABLE=1

# (Recomendado en producción) Orígenes del front que pueden llamar al API desde el navegador (coma, sin espacios extra).
# Ej.: GIS_ALLOWED_ORIGINS=https://tu-proyecto.vercel.app,https://www.tu-dominio.com
# Sin esto en Vercel/producción el servidor sigue aceptando cualquier origen (CORS permisivo).

# En producción, GET /api/db-check exige sesión JWT (mismo token que el editor). Para dejarlo público (no recomendado):
# GIS_DB_CHECK_PUBLIC=1
